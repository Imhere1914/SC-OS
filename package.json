{
  "name": "ai-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AI Operating System — branded business OS for SC & HFM (standalone)",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"node --env-file=.env --watch --import tsx/esm server/index.ts\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "node --env-file=.env --import tsx/esm server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.0.5",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.87.0",
    "hono": "^4.6.14",
    "motion": "^11.15.0",
    "nanoid": "^5.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.87.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
